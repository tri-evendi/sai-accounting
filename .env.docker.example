# ─────────────────────────────────────────────────────────────
# Docker Compose environment — copy to `.env` and fill in.
#   cp .env.docker.example .env
# The .env file is read by all three services (db, migrate, app).
# ─────────────────────────────────────────────────────────────

# ─── Database credentials (consumed by the `db` service) ─────
DB_NAME=sai_production
DB_USER=sai
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-different-root-password

# ─── App → database connection ───────────────────────────────
# Host is the compose service name `db`, NOT localhost.
# Must match DB_USER / DB_PASSWORD / DB_NAME above.
# If the password contains special chars (@ : / etc.), URL-encode them here.
DATABASE_URL="mysql://sai:change-me-strong-password@db:3306/sai_production"
# Connection pool size per app instance (default 3).
DB_CONNECTION_LIMIT=3

# ─── NextAuth (required) ──────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
# Public URL users reach the app on (no trailing slash).
# Must use the same host as APP_DOMAIN below (Traefik terminates TLS → https).
AUTH_URL="https://inventory.suburanugerahindonesia.com"
# Required when running behind Docker / a reverse proxy.
AUTH_TRUST_HOST=true

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_NAME="SAI Management"
TZ="Asia/Jakarta"

# ─── Traefik routing ──────────────────────────────────────────
# Public domain Traefik routes to this app. Must have DNS pointing at the
# Traefik host, and match the AUTH_URL host above.
APP_DOMAIN=inventory.suburanugerahindonesia.com

# Demo seed only — NEVER set true in production.
# ALLOW_SEED=true
