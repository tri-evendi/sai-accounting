generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Users & Auth ────────────────────────────────────────

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique @db.VarChar(50)
  password String   @db.VarChar(255)
  name     String?  @db.VarChar(100)
  role     String   @default("core") @db.VarChar(20) // bos, core, ptg
  status   Int      @default(1) // 1 = must change password
  passDate DateTime? @map("pass_date")

  // ─── issue #11 — Mode Akuntan (accountant mode) ────────────
  /// Per-user DISPLAY preference for "Mode Akuntan". Nullable on purpose:
  ///   NULL  = follow the role default (bos → ON, core/ptg → OFF),
  ///   true  = explicitly show accounting surfaces (Jurnal/Buku Besar/COA + debit/kredit terms),
  ///   false = explicitly hide them.
  /// An explicit value overrides the role default; a user who never toggles
  /// stays NULL and tracks their role's default even if their role changes.
  /// Display-only — it NEVER changes authorisation (role still gates every
  /// accounting page) nor what is posted. See src/lib/accountant-mode.ts.
  accountantMode Boolean? @map("accountant_mode")
  // ───────────────────────────────────────────────────────────

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  closedPeriods Period[]

  @@map("users")
}

// ─── Contracts ───────────────────────────────────────────

model Contract {
  id          Int      @id @default(autoincrement())
  contractNo  String   @unique @map("contract_no") @db.VarChar(50)
  date        DateTime
  /// Structured payment due date for AR aging (issue #12). NULL = unknown:
  /// `top1`/`top2` are free-text commercial terms, never parsed into a date.
  /// A contract with no due date is aged from `date` and never flagged overdue.
  dueDate     DateTime? @map("due_date")
  buyer       String   @db.VarChar(100)
  // ─── issue #22 — Master Consignee ──────────────────────
  /// Legacy free-text consignee. Kept as a FALLBACK: when a contract resolves to
  /// a `Consignee` master row it also carries `consigneeId`, but rows whose text
  /// never matched a master keep this string and a NULL `consigneeId`, so no
  /// legacy consignee information is ever lost. Shown only when the relation is
  /// absent (the master name wins when present).
  consignee   String?  @db.VarChar(100)
  /// Nullable FK to the Consignee master (issue #22). NULL on legacy rows whose
  /// free text did not resolve — those fall back to the `consignee` string above.
  consigneeId Int?     @map("consignee_id")
  packaging   String?  @db.VarChar(100)
  shipment    String?  @db.VarChar(200)
  top1        String?  @db.VarChar(200)
  top2        String?  @db.VarChar(200)
  currency    String   @default("USD") @db.VarChar(5)
  /// Nullable on purpose — a DEFAULT 1 would value historical foreign-currency
  /// contracts at 1:1 IDR, the exact bug #36 fixes. Legacy rows keep a NULL rate
  /// and are reported as "kurs belum diisi" rather than guessed at. See Invoice.rate.
  rate        Decimal? @db.Decimal(18, 6)
  /// Contract value (sum of items) in IDR base, at `rate`.
  baseAmount  Decimal? @map("base_amount") @db.Decimal(15, 2)
  status      String   @default("pending") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items     ContractItem[]
  payments  ContractPayment[]
  documents Document[]
  advances  AdvancePayment[]
  // issue #22 — master consignee relation (RESTRICT: a consignee in use is
  // deactivated, never hard-deleted; see Consignee).
  consigneeRef Consignee? @relation(fields: [consigneeId], references: [id], onDelete: Restrict)

  @@index([dueDate])
  @@index([date])
  @@index([consigneeId])
  @@map("contracts")
}

model ContractItem {
  id         Int      @id @default(autoincrement())
  contractId Int      @map("contract_id")
  itemName   String   @map("item_name") @db.VarChar(100)
  bags       Int      @default(0)
  kgPerBag   Decimal  @default(0) @map("kg_per_bag") @db.Decimal(10, 2)
  pricePerKg Decimal  @default(0) @map("price_per_kg") @db.Decimal(10, 2)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_items")
}

model ContractPayment {
  id         Int      @id @default(autoincrement())
  contractId Int      @map("contract_id")
  date       DateTime
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("USD") @db.VarChar(5)
  // Nullable on purpose: legacy rows have no rate. Posting refuses to guess a
  // rate for foreign currency — it demands an explicit one instead (issue #9).
  rate       Decimal? @db.Decimal(18, 6)
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  note       String?  @db.Text

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_payments")
}

// ─── Invoices (Faktur) ───────────────────────────────────

model Invoice {
  id         Int      @id @default(autoincrement())
  invoiceNo  String   @unique @map("invoice_no") @db.VarChar(50)
  date       DateTime
  /// Structured payment due date for AR aging (issue #12). NULL = unknown, and
  /// deliberately never backfilled — an invented due date would drive a false
  /// "Jatuh Tempo" alarm. NULL rows age from `date` instead.
  dueDate    DateTime? @map("due_date")
  status     String   @default("pending") @db.VarChar(20)
  /// Nullable: legacy invoices predate the customer link (issue #35).
  customerId Int?     @map("customer_id")
  currency   String   @default("IDR") @db.VarChar(5)
  /// Nullable on purpose — a DEFAULT 1 would value historical foreign-currency
  /// invoices at 1:1 IDR, the exact bug #35 fixes. See InvoicePayment.rate.
  rate       Decimal? @db.Decimal(18, 6)
  /// Gross invoice value (subtotal + tax) in IDR base.
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  /// PPN Keluaran, in `currency`. 0 = untaxed document.
  taxAmount  Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  // ── PPN as a first-class field (issue #16) ──────────────────────────────────
  /// Whether PPN Keluaran applies. FALSE = untaxed / export (0%): the posting
  /// engine then emits no VAT line at all. DEFAULTs FALSE so every pre-#16 row
  /// keeps posting exactly as it did (it carried tax_amount 0 already).
  taxable    Boolean  @default(false)
  /// Effective PPN rate applied, in percent (e.g. 11.00; 0.00 for export).
  /// NULLable, no backfill — same posture as `rate`/`base_amount` (migrations
  /// 0005/0008): a legacy row's rate is unknown, not zero, so it is left NULL and
  /// `tax_amount` (which IS stored) remains authoritative for what was posted.
  taxRate    Decimal? @map("tax_rate") @db.Decimal(15, 2)
  /// DPP — Dasar Pengenaan Pajak (tax base), in `currency`. Equals the net line
  /// subtotal; stored so the Faktur Pajak base is captured explicitly rather than
  /// only re-derivable from items. NULLable/no-backfill for legacy rows, where the
  /// subtotal is still recomputed from `items` (see the invoice detail page).
  dpp        Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer?        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    InvoiceItem[]
  payments InvoicePayment[]
  /// Sales advances compensated into this invoice (issue #26). Each row both
  /// reduces what the customer still owes and carries its own journal.
  advanceApplications AdvanceApplication[]
  /// Retur penjualan against this invoice (issue #27). The origin document of
  /// every sales return; the total returned is capped at what was invoiced.
  salesReturns SalesReturn[]

  @@index([customerId])
  @@index([dueDate])
  @@index([date])
  @@map("invoices")
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int     @map("invoice_id")
  itemName  String  @map("item_name") @db.VarChar(100)
  quantity  Decimal @default(0) @db.Decimal(10, 2)
  price     Decimal @default(0) @db.Decimal(15, 2)
  unit      String? @db.VarChar(20)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  /// Retur penjualan lines that reference THIS invoice line (issue #27). Used to
  /// sum how much of this line has already been returned, per source line.
  salesReturnItems SalesReturnItem[]

  @@map("invoice_items")
}

model InvoicePayment {
  id         Int      @id @default(autoincrement())
  invoiceId  Int      @map("invoice_id")
  date       DateTime
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("USD") @db.VarChar(5)
  rate       Decimal? @db.Decimal(18, 6) // nullable: legacy rows have none (see ContractPayment)
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  note       String?  @db.Text

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_payments")
}

// ─── Inventory & Stock ───────────────────────────────────

model Item {
  id    Int     @id @default(autoincrement())
  name  String  @unique @db.VarChar(100)
  unit  String? @db.VarChar(20)

  stock Stock[]
  /// Return lines that move THIS item back in/out of stock (issue #27).
  salesReturnItems    SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@map("items")
}

model Stock {
  id       Int      @id @default(autoincrement())
  itemId   Int      @map("item_id")
  quantity Decimal  @db.Decimal(10, 2)
  type     String   @db.VarChar(10) // enum-like: in, out
  date     DateTime
  /// IDR cost per unit for `in` movements — the input to weighted-average COGS.
  /// Nullable: legacy rows carry no cost and are skipped by the average.
  unitCost Decimal? @map("unit_cost") @db.Decimal(15, 2)
  note     String?  @db.Text

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("stock")
}

// ─── Suppliers & Customers ───────────────────────────────

model Supplier {
  id      Int     @id @default(autoincrement())
  name    String  @db.VarChar(100)
  address String? @db.Text
  phone   String? @db.VarChar(30)
  email   String? @db.VarChar(100)

  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  transactions SupplierTransaction[]
  advances     AdvancePayment[]
  purchaseReturns PurchaseReturn[]

  @@map("suppliers")
}

model SupplierTransaction {
  id         Int      @id @default(autoincrement())
  supplierId Int      @map("supplier_id")
  date       DateTime
  /// Structured payment due date for AP aging (issue #12). Meaningful only on
  /// `purchase` rows; NULL = unknown, aged from `date` and never flagged overdue.
  dueDate    DateTime? @map("due_date")
  type       String   @db.VarChar(20) // enum-like: purchase, payment
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("IDR") @db.VarChar(5)
  rate       Decimal? @db.Decimal(18, 6) // nullable: legacy rows have none (see ContractPayment)
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  taxAmount  Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2) // PPN Masukan portion
  note       String?  @db.Text

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  /// Allocations where THIS row is the payment (issue #37). Empty on a purchase,
  /// and empty on a legacy payment that predates allocation — see `paidBase`
  /// fallback in `getPayables`.
  allocationsMade     SupplierPaymentAllocation[] @relation("allocation_payment")
  /// Allocations where THIS row is the purchase being settled.
  allocationsReceived SupplierPaymentAllocation[] @relation("allocation_purchase")
  /// Purchase advances compensated into THIS purchase row (issue #26). Empty on
  /// a `payment` row — only a purchase carries an obligation to compensate.
  advanceApplications AdvanceApplication[]
  /// Retur pembelian against THIS purchase row (issue #27). Empty on a `payment`
  /// row — only a `purchase` is a document goods can be returned against.
  purchaseReturns PurchaseReturn[]

  @@index([supplierId, type])
  @@index([dueDate])
  @@map("supplier_transactions")
}

/// Links a supplier `payment` row to the `purchase` row(s) it settles (issue #37).
///
/// WHY A TABLE AND NOT A NULLABLE `applied_to_id` ON `supplier_transactions`:
/// a single bank transfer routinely clears several invoices, and a single invoice
/// is routinely cleared by several instalments. A self-FK models only one payment
/// → one purchase, so the many-to-many case would have to be faked by splitting
/// the payment row — which would invent journal entries that never happened. This
/// table records the split without adding a journal of its own: `postJournal`
/// still sees exactly one purchase and one payment.
///
/// LEDGER-AFFECTING FOR FOREIGN PAYMENTS (issue #42). For a PURE-IDR payment the
/// allocation is reporting data — no rate, no selisih kurs, nothing to post. But
/// since #23 a FOREIGN payment relieves each slice of hutang at the DOCUMENT rate
/// of the purchase it settles, so the allocation determines which rate — and thus
/// the realised FX difference — of each slice. Editing a foreign payment's
/// allocation therefore changes the correct journal, and the write site reposts
/// the payment (`repostForSource`) so the journal can never go stale.
///
/// `amount` is denominated in the PAYMENT's currency (it is a slice of that
/// payment), and `base_amount` carries the IDR value at the payment's own `rate`
/// — the same rate the ledger posted at. `getPayables` sums `base_amount` only,
/// never `amount`, so allocations across currencies are never added together.
/// `base_amount` is NULLable for the same reason it is everywhere else: a legacy
/// foreign payment with no rate has no honest IDR value, and such rows are
/// excluded from the sums and counted rather than valued 1:1.
model SupplierPaymentAllocation {
  id         Int      @id @default(autoincrement())
  paymentId  Int      @map("payment_id")
  purchaseId Int      @map("purchase_id")
  /// Portion of the payment applied to this purchase, in the payment's currency.
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("IDR") @db.VarChar(5)
  rate       Decimal? @db.Decimal(18, 6)
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Payment side stays CASCADE: deleting a payment reverses ITS journal first
  // (the transactions DELETE route unposts before delete), so the allocations
  // may fall away with a journal that is already reversed — nothing is orphaned.
  payment  SupplierTransaction @relation("allocation_payment", fields: [paymentId], references: [id], onDelete: Cascade)
  // Purchase side is RESTRICT (issue #42), NOT cascade. Deleting a purchase does
  // NOT touch the paying payment's journal, so cascading its allocation away
  // would leave that journal relieving a hutang slice — at this purchase's
  // document rate — for a purchase that no longer exists: a stale journal. The
  // route refuses the delete until the allocation is cleared (which reposts the
  // payment). Same spirit as `advance_applications`' RESTRICT, one step removed:
  // there the row owns a journal; here it feeds another row's journal.
  purchase SupplierTransaction @relation("allocation_purchase", fields: [purchaseId], references: [id], onDelete: Restrict)

  /// One row per (payment, purchase) pair: a second application of the same
  /// payment to the same purchase is an edit of the first, not a new fact.
  @@unique([paymentId, purchaseId])
  @@index([purchaseId])
  @@map("supplier_payment_allocations")
}

model Customer {
  id      Int     @id @default(autoincrement())
  name    String  @db.VarChar(100)
  address String? @db.Text
  phone   String? @db.VarChar(30)
  email   String? @db.VarChar(100)
  pic     String? @db.VarChar(100)
  /// Bebas PPN (issue #16) — a customer never charged PPN Keluaran (an export
  /// buyer, or a non-PKP counterparty). Drives the invoice form's default to
  /// non-taxable; the form control can still override it per document. DEFAULT
  /// FALSE, so existing customers keep the standard domestic 11% default.
  taxExempt Boolean @default(false) @map("tax_exempt")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoices Invoice[]
  advances AdvancePayment[]
  salesReturns SalesReturn[]

  @@map("customers")
}

// ─── issue #22 — Master Consignee (penerima barang ekspor) ─
//
// Modelled from legacy `tb_consignee` (company_name / address / phone / email /
// pic). The export consignee used to live only as free text on `contracts`;
// this promotes it to reusable master data so it can also feed Surat Jalan
// (issue #14). Master data is DEACTIVATED (`is_active = false`), never
// hard-deleted, once referenced by a contract — the FK from Contract is RESTRICT.
model Consignee {
  id      Int     @id @default(autoincrement())
  name    String  @db.VarChar(100)
  address String? @db.Text
  /// Negara tujuan/penerima (ekspor). Free text — not an ISO code.
  country String? @db.VarChar(60)
  /// Kontak / PIC (nama, telepon, atau email) — free text, mirrors legacy `pic`.
  contact String? @db.VarChar(100)
  notes   String? @db.Text

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contracts Contract[]

  @@index([isActive])
  @@index([name])
  @@map("consignees")
}

// ─── Uang Muka / Advance payments (issue #26) ────────────

/// Money moved BEFORE the document that will justify it exists.
///
/// WHY A NEW TABLE AND NOT A TYPE/FLAG ON THE EXISTING PAYMENT MODELS:
/// `InvoicePayment.invoiceId` and `ContractPayment.contractId` are NOT NULL, and
/// that is the whole point of an advance — there is no invoice yet. Relaxing
/// either FK to hold a "payment" that settles nothing would make the column a
/// lie for every other row and force every existing reader (`settleDocument`,
/// the posting engine, which dereferences `payment.invoice.invoiceNo`) to grow a
/// null branch for a case that is not a payment at all.
///
/// `SupplierTransaction.type` is the precedent for discriminating *direction*
/// inside one table, and that is exactly how it is used here: `sales` and
/// `purchase` advances are the same fact pointing opposite ways, so they share
/// this table and differ by `type`. What that precedent does NOT cover is the
/// sales side — there is no customer-side equivalent of `supplier_transactions`
/// to add a type to. One table serving both directions is the smaller change.
///
/// Remaining balance is DERIVED (`amount` − Σ applications), never stored, for
/// the reason `receivables.ts` gives about `payment_status`: a denormalised copy
/// drifts the instant an application is added, edited or reversed.
model AdvancePayment {
  id         Int      @id @default(autoincrement())
  advanceNo  String   @unique @map("advance_no") @db.VarChar(50)
  /// enum-like: sales (Uang Muka Penjualan, a LIABILITY — we owe goods)
  ///          | purchase (Uang Muka Pembelian, an ASSET — supplier owes goods)
  type       String   @db.VarChar(20)
  date       DateTime
  /// Exactly one of these two is set, per `type`. Both nullable because a sales
  /// advance has no supplier and a purchase advance has no customer.
  customerId Int?     @map("customer_id")
  supplierId Int?     @map("supplier_id")
  /// Optional link to the contract the advance was received against (issue #26
  /// asks for it). Advisory only — compensation targets an invoice/purchase.
  contractId Int?     @map("contract_id")
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("IDR") @db.VarChar(5)
  /// Nullable, no DEFAULT 1, no backfill — same posture as Invoice.rate and
  /// Contract.rate: a foreign advance with no rate has NO honest IDR value and
  /// is excluded from IDR sums and surfaced, never valued 1:1.
  rate       Decimal? @db.Decimal(18, 6)
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  /// enum-like: open | canceled. "Fully compensated" is derived, not stored.
  status     String   @default("open") @db.VarChar(20)
  note       String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer     Customer?            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  supplier     Supplier?            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  contract     Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  applications AdvanceApplication[]

  @@index([customerId])
  @@index([supplierId])
  @@index([contractId])
  @@index([date])
  @@index([type, status])
  @@map("advance_payments")
}

/// One compensation: part (or all) of an advance moved against an invoice or a
/// supplier purchase, reducing what is still owed.
///
/// WHY A TABLE AND NOT A `compensated_invoice_id` ON `advance_payments`:
/// the same argument migration 0009 makes for `supplier_payment_allocations`.
/// One advance routinely covers several invoices (a 30% down-payment spread
/// over three shipments) and one invoice is routinely covered by several
/// advances. A single nullable FK models neither, and faking the many-to-many by
/// splitting the advance row would invent cash receipts that never happened.
///
/// THIS TABLE HAS ITS OWN JOURNAL; `supplier_payment_allocations` DOES NOT.
/// A supplier allocation carries no journal of its own — it only shapes the
/// paying payment's journal, and does so only for a foreign payment (issue #42).
/// A compensation is itself an accounting event: it moves value out of Uang Muka
/// and against Piutang/Hutang, and neither the advance's journal nor the
/// invoice's journal contains that movement. So every row here is a posting
/// source (`sourceType: "advance_application"`) with its own journal, and
/// deleting one must reverse that journal rather than silently cascade — which
/// is why its FKs are RESTRICT. (A supplier allocation reaches the same "never
/// orphan a journal" guarantee differently: RESTRICT on its purchase side, plus
/// an auto-repost of the payment whenever its allocation set is edited.)
///
/// `amount` is denominated in the ADVANCE's currency — it is a slice of the
/// advance — and `base_amount` is its IDR value at the advance's own `rate`, the
/// rate the ledger relieved Uang Muka at. Sums are taken over `base_amount`
/// only, so no two currencies are ever added.
model AdvanceApplication {
  id         Int      @id @default(autoincrement())
  advanceId  Int      @map("advance_id")
  /// Target of the compensation: an invoice (sales advance) or a
  /// `supplier_transactions` row of type `purchase` (purchase advance).
  /// Exactly one is set — enforced in Zod, not by the DB, because MySQL has no
  /// partial CHECK the way a filtered unique index would need.
  invoiceId  Int?     @map("invoice_id")
  purchaseId Int?     @map("purchase_id")
  date       DateTime
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("IDR") @db.VarChar(5)
  rate       Decimal? @db.Decimal(18, 6)
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  note       String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  advance  AdvancePayment       @relation(fields: [advanceId], references: [id], onDelete: Restrict)
  invoice  Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  purchase SupplierTransaction? @relation(fields: [purchaseId], references: [id], onDelete: Restrict)

  /// One row per (advance, target) pair: compensating the same advance into the
  /// same invoice twice is an edit of the first, not a second event. MySQL
  /// treats NULLs as distinct, so the unused half of each pair never collides.
  @@unique([advanceId, invoiceId])
  @@unique([advanceId, purchaseId])
  @@index([invoiceId])
  @@index([purchaseId])
  @@index([date])
  @@map("advance_applications")
}

// ─── Retur penjualan & pembelian (issue #27) ─────────────

/// A sales return (retur penjualan) — goods a customer sent back, reversing part
/// of an invoice.
///
/// WHY IT REFERENCES THE ORIGIN INVOICE, NOT A FREE-STANDING CREDIT NOTE:
/// a return can never exceed what was sold, so the acceptance criterion "tidak
/// bisa meretur melebihi kuantitas/nilai dokumen asal" is enforced against the
/// origin. The header carries `invoiceId`; each item carries `invoiceItemId`, so
/// the cap is checked per source line, netting off returns already made.
///
/// CURRENCY DISCIPLINE (issue #43 posture, applied to returns): a return inherits
/// the origin invoice's `currency` and `rate` and is booked at THAT rate — it is a
/// partial reversal of the invoice, valued exactly as the invoice was. No
/// settlement rate is re-resolved: nothing here is "settled at today's rate", so
/// there is no realised FX and no `fx_gain_loss` leg. `rate` is NULLable with the
/// same posture as everywhere else — a foreign origin with no rate has no honest
/// IDR value; Zod refuses to create such a return rather than book it 1:1.
model SalesReturn {
  id         Int      @id @default(autoincrement())
  returnNo   String   @unique @map("return_no") @db.VarChar(50)
  /// Origin invoice this return reverses part of (issue #27). RESTRICT: an
  /// invoice with returns against it cannot be deleted out from under them.
  invoiceId  Int      @map("invoice_id")
  /// Copied from the invoice for convenience; a sales return has a customer only
  /// insofar as the invoice does (legacy invoices may carry none).
  customerId Int?     @map("customer_id")
  date       DateTime
  /// Inherited from the origin invoice, never re-chosen.
  currency   String   @default("IDR") @db.VarChar(5)
  /// The invoice's own rate. NULLable/no-DEFAULT-1: see the model comment.
  rate       Decimal? @db.Decimal(18, 6)
  /// Net returned value (Σ line qty × price), in `currency`. Excludes PPN.
  subtotal   Decimal  @default(0) @db.Decimal(15, 2)
  /// Reversed PPN Keluaran, proportional to the returned value, in `currency`.
  /// 0 when the origin invoice was untaxed / 0% export → no VAT leg is posted.
  taxAmount  Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  /// Effective PPN rate reversed, in percent. NULL when the origin was untaxed.
  taxRate    Decimal? @map("tax_rate") @db.Decimal(15, 2)
  /// Gross returned value (subtotal + tax) in IDR base — the amount credited to
  /// Piutang Usaha. NULLable for an unrated foreign origin, as elsewhere.
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  /// enum-like: posted | canceled. A canceled return is excluded from the caps.
  status     String   @default("posted") @db.VarChar(20)
  reason     String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice  Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  customer Customer?         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    SalesReturnItem[]

  @@index([invoiceId])
  @@index([customerId])
  @@index([date])
  @@index([status])
  @@map("sales_returns")
}

model SalesReturnItem {
  id            Int     @id @default(autoincrement())
  salesReturnId Int     @map("sales_return_id")
  /// The invoice line being returned — the source line the over-return cap is
  /// measured against. RESTRICT so the line cannot vanish under a return.
  invoiceItemId Int     @map("invoice_item_id")
  itemName      String  @map("item_name") @db.VarChar(100)
  /// Returned quantity, capped at the source line's quantity net of prior
  /// returns. Decimal(15,3) per docs/DATABASE.md.
  quantity      Decimal @db.Decimal(15, 3)
  /// Unit price, copied from the invoice line (the value being reversed).
  price         Decimal @default(0) @db.Decimal(15, 2)
  /// Optional link to the stock Item so the goods can move back IN (issue #27).
  /// NULL = this line is not tracked in inventory (the app couples sales and
  /// stock loosely; invoice lines are free-text, not FKs to Item).
  itemId        Int?    @map("item_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesReturn SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  invoiceItem InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Restrict)
  item        Item?       @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([salesReturnId])
  @@index([invoiceItemId])
  @@index([itemId])
  @@map("sales_return_items")
}

/// A purchase return (retur pembelian) — goods we sent back to a supplier,
/// reversing part of a purchase.
///
/// ASYMMETRY WITH SALES: a purchase (`supplier_transactions` of type `purchase`)
/// has NO line items in this schema — it is a single net `amount` plus
/// `tax_amount`. So a purchase return references the origin purchase DOCUMENT and
/// the over-return cap is enforced by VALUE (net subtotal) against the purchase's
/// amount, netting off prior returns — there is no source line to reference. Its
/// items are free-text (like invoice items), for the nota retur and stock only.
model PurchaseReturn {
  id         Int      @id @default(autoincrement())
  returnNo   String   @unique @map("return_no") @db.VarChar(50)
  /// Origin purchase (a `supplier_transactions` row of type `purchase`).
  purchaseId Int      @map("purchase_id")
  supplierId Int?     @map("supplier_id")
  date       DateTime
  currency   String   @default("IDR") @db.VarChar(5)
  rate       Decimal? @db.Decimal(18, 6)
  /// Net returned value, in `currency`, capped at the purchase's remaining net.
  subtotal   Decimal  @default(0) @db.Decimal(15, 2)
  /// Reversed PPN Masukan, proportional to the returned value. 0 → no VAT leg.
  taxAmount  Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  taxRate    Decimal? @map("tax_rate") @db.Decimal(15, 2)
  /// Gross returned value in IDR base — the amount debited to Hutang Usaha.
  baseAmount Decimal? @map("base_amount") @db.Decimal(15, 2)
  status     String   @default("posted") @db.VarChar(20)
  reason     String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchase SupplierTransaction  @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  supplier Supplier?            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items    PurchaseReturnItem[]

  @@index([purchaseId])
  @@index([supplierId])
  @@index([date])
  @@index([status])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               Int     @id @default(autoincrement())
  purchaseReturnId Int     @map("purchase_return_id")
  itemName         String  @map("item_name") @db.VarChar(100)
  quantity         Decimal @db.Decimal(15, 3)
  price            Decimal @default(0) @db.Decimal(15, 2)
  /// Optional link to the stock Item so the goods can move OUT (issue #27).
  itemId           Int?    @map("item_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  item           Item?          @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([purchaseReturnId])
  @@index([itemId])
  @@map("purchase_return_items")
}

// ─── Financial ───────────────────────────────────────────

model CashAccount {
  id          Int      @id @default(autoincrement())
  type        String   @db.VarChar(20)
  date        DateTime
  description String   @db.VarChar(255)
  currency    String   @default("IDR") @db.VarChar(5)
  debit       Decimal  @default(0) @db.Decimal(15, 2)
  credit      Decimal  @default(0) @db.Decimal(15, 2)
  rate        Decimal? @db.Decimal(18, 6) // nullable: legacy rows have none (see ContractPayment)
  baseAmount  Decimal? @map("base_amount") @db.Decimal(15, 2)
  note        String?  @db.Text

  // ── Bank reconciliation markers (issue #24) ──────────────
  // Set when this book movement is matched to a bank-statement line. Purely a
  // reconciliation flag — matching posts NO journal and moves no money.
  reconciled   Boolean   @default(false)
  reconciledAt DateTime? @map("reconciled_at")
  /// The reconciliation (bank_statements row) this movement was matched under.
  statementId  Int?      @map("statement_id")

  createdAt DateTime @default(now()) @map("created_at")

  statement     BankStatement?     @relation("StatementMovements", fields: [statementId], references: [id], onDelete: SetNull)
  statementLine BankStatementLine? @relation("LineMatch")

  @@index([statementId])
  @@index([reconciled])
  @@map("cash_accounts")
}

model CurrencyConversion {
  id       Int      @id @default(autoincrement())
  date     DateTime
  fromCur  String   @map("from_currency") @db.VarChar(5)
  toCur    String   @map("to_currency") @db.VarChar(5)
  amount   Decimal  @db.Decimal(15, 2)
  rate     Decimal  @db.Decimal(15, 4)
  result   Decimal  @db.Decimal(15, 2)

  @@map("currency_conversions")
}

// ─── Accounting: settlement-date exchange rates (issue #43) ──

/// The rate of one foreign currency against IDR on one calendar day.
///
/// ── WHY THIS EXISTS, GIVEN #23 REJECTED IT ──────────────────────────────────
/// Issue #23 refused an `exchange_rates` table because a second rate source can
/// contradict the rate a document already asserts. That objection stands and is
/// enforced by *scope*, not by good intentions: nothing values a document from
/// this table. An invoice, contract, purchase, advance or payment is valued at
/// the rate stored on itself, resolved by `resolveRate`, exactly as before.
///
/// This table answers the one question no document can answer — the question
/// #43 is about: "a customer wired IDR against a USD invoice; how many USD did
/// that transfer settle?" The IDR payment knows its own rate (1). The USD
/// invoice knows the rate it was *booked* at, months ago. Neither knows what a
/// dollar was worth on the day the money landed. So this COMPLEMENTS document
/// rates rather than overriding them: it is read only on the cross-currency
/// settlement path, and only for the currency of the document being relieved.
///
/// ── EXACT DATE ONLY ─────────────────────────────────────────────────────────
/// Lookups match one calendar day. There is deliberately no nearest / previous /
/// interpolate fallback: every one of those is a silent guess of the kind
/// `resolveRate` exists to refuse, and here the guess would decide how much
/// receivable is discharged. A missing row fails loudly instead
/// (`MissingSettlementRateError`), and the user records the rate from the bank
/// advice — the same number they would have typed onto the payment anyway.
///
/// `@@unique([currency, rateDate])` is the anti-contradiction guard: one rate
/// per currency per day, so the table can never hold two answers at once.
model ExchangeRate {
  id       Int      @id @default(autoincrement())
  currency String   @db.VarChar(5) // ISO code of the FOREIGN currency; the quote is always against IDR
  rateDate DateTime @map("rate_date") @db.Date
  /// Units of IDR per 1 unit of `currency` — same direction as every `rate`
  /// column on the documents, so the two are never accidentally inverted.
  rate     Decimal  @db.Decimal(18, 6)
  /// Where the number came from (bank advice no., Kurs Pajak, BI middle rate).
  source   String?  @db.VarChar(100)
  isActive Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([currency, rateDate])
  @@index([rateDate])
  @@index([currency])
  @@map("exchange_rates")
}

// ─── Accounting: Chart of Accounts ───────────────────────

model Account {
  id            Int      @id @default(autoincrement())
  code          String   @unique @db.VarChar(20)
  name          String   @db.VarChar(150)
  type          String   @db.VarChar(30) // enum-like: cash_bank, account_receivable, inventory, ... (see src/lib/accounting.ts)
  normalBalance String   @map("normal_balance") @db.VarChar(6) // debit | credit
  parentId      Int?     @map("parent_id")
  currency      String   @default("IDR") @db.VarChar(5)
  isActive      Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent      Account?      @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]
  mappings     AccountMapping[]

  @@index([parentId])
  @@index([type])
  @@map("accounts")
}

// ─── Accounting: Auto-posting account mappings ───────────

/// Maps a posting rule slot (`key`) to a real COA account, so posting rules never
/// hardcode account codes. `currency` = "any" is the fallback/default mapping;
/// a row with a concrete ISO code (e.g. "CNY") overrides it for that currency.
/// Keys are enum-like lowercase snake_case — see src/lib/posting/mapping.ts.
model AccountMapping {
  id        Int      @id @default(autoincrement())
  key       String   @db.VarChar(50) // ar_default, sales_default, vat_out, vat_in, ap_default, inventory, cogs, cash_default, ...
  accountId Int      @map("account_id")
  currency  String   @default("any") @db.VarChar(5) // ISO code, or "any" for the default mapping
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([key, currency])
  @@index([accountId])
  @@index([key])
  @@map("account_mappings")
}

// ─── Accounting: Journals (double-entry) ─────────────────

model Journal {
  id           Int      @id @default(autoincrement())
  number       String   @unique @db.VarChar(30)
  date         DateTime
  type         String   @default("general") @db.VarChar(20) // general, sales, purchase, cash, adjustment, reversal
  sourceType   String?  @map("source_type") @db.VarChar(30) // auto-posting origin (e.g. invoice)
  sourceId     Int?     @map("source_id")
  note         String?  @db.Text
  isReversed   Boolean  @default(false) @map("is_reversed")
  reversalOfId Int?     @map("reversal_of_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lines      JournalLine[]
  reversalOf Journal?      @relation("JournalReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversals  Journal[]     @relation("JournalReversal")

  @@index([date])
  @@index([type])
  @@index([sourceType, sourceId])
  @@map("journals")
}

model JournalLine {
  id         Int     @id @default(autoincrement())
  journalId  Int     @map("journal_id")
  accountId  Int     @map("account_id")
  debit      Decimal @default(0) @db.Decimal(15, 2) // original currency
  credit     Decimal @default(0) @db.Decimal(15, 2)
  currency   String  @default("IDR") @db.VarChar(5)
  rate       Decimal @default(1) @db.Decimal(18, 6) // to IDR base
  baseDebit  Decimal @default(0) @map("base_debit") @db.Decimal(15, 2) // IDR base
  baseCredit Decimal @default(0) @map("base_credit") @db.Decimal(15, 2)
  memo       String? @db.VarChar(255)

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalId])
  @@index([accountId])
  @@map("journal_lines")
}

// ─── Accounting: Period lock (tutup buku) ────────────────

/// One row per calendar month that has ever been closed or explicitly opened.
/// A month with no row is treated as open — closing is opt-in, so the lock can
/// be introduced on an existing database without freezing history.
model Period {
  id       Int       @id @default(autoincrement())
  year     Int
  month    Int // 1-12
  status   String    @default("open") @db.VarChar(20) // open, closed
  closedAt DateTime? @map("closed_at")
  /// Who performed the last close. Kept as a FK so the name stays correct if the
  /// user is renamed; the full close/reopen history lives in the audit log.
  closedById Int?    @map("closed_by_id")
  note       String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  closedBy User? @relation(fields: [closedById], references: [id], onDelete: Restrict)

  @@unique([year, month])
  @@index([status])
  @@index([closedById])
  @@map("periods")
}

// ─── Documents ───────────────────────────────────────────

model Document {
  id         Int      @id @default(autoincrement())
  contractId Int?     @map("contract_id")
  filename   String   @db.VarChar(255)
  filepath   String   @db.VarChar(500)
  type       String?  @db.VarChar(50)
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@map("documents")
}

// ─── Bank Reconciliation (issue #24) ─────────────────────
// Rekonsiliasi Bank: cocokkan buku kas/bank internal (`cash_accounts`,
// type = "bank") dengan rekening koran bank. Matching **tidak** memposting
// jurnal — hanya menandai bahwa satu baris buku bersesuaian dengan satu baris
// koran. Impor baris koran = manual atau CSV (SmartLink e-Banking di luar scope).

/// One imported/entered bank statement for one bank account over one period.
/// The "bank account" is the (`cashType`, `currency`) pair, mirroring how
/// `cash_accounts` identifies a book — this schema has no bank-account master.
model BankStatement {
  id             Int       @id @default(autoincrement())
  /// Which internal cash book this reconciles. Always `bank` in practice — kas
  /// fisik has no rekening koran — but stored so (cashType, currency) names it.
  cashType       String    @default("bank") @map("cash_type") @db.VarChar(20)
  /// A bank account holds exactly one currency; the balances below are in it.
  /// Never summed across currencies — foreign statements stay in their own unit.
  currency       String    @default("IDR") @db.VarChar(5)
  periodStart    DateTime  @map("period_start")
  periodEnd      DateTime  @map("period_end")
  openingBalance Decimal   @default(0) @map("opening_balance") @db.Decimal(15, 2)
  closingBalance Decimal   @default(0) @map("closing_balance") @db.Decimal(15, 2)
  /// enum-like: draft = sedang direkonsiliasi; locked = selesai & dikunci.
  /// A locked statement refuses further match/unmatch until reopened.
  status         String    @default("draft") @db.VarChar(20)
  lockedAt       DateTime? @map("locked_at")
  note           String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lines     BankStatementLine[]
  movements CashAccount[]       @relation("StatementMovements")

  // One statement per account (cashType+currency) per exact period.
  @@unique([cashType, currency, periodStart, periodEnd])
  @@index([status])
  @@index([periodStart])
  @@map("bank_statements")
}

/// One line of a bank statement (one mutasi koran). Manual or CSV imported.
model BankStatementLine {
  id            Int      @id @default(autoincrement())
  statementId   Int      @map("statement_id")
  date          DateTime
  description   String   @db.VarChar(255)
  /// Signed money: positive = masuk ke rekening (menambah saldo bank),
  /// negative = keluar. Sepadan dengan (debit − credit) di `cash_accounts`.
  amount        Decimal  @db.Decimal(15, 2)
  matched       Boolean  @default(false)
  /// The single book movement (1:1) this line is matched to. SetNull so deleting
  /// a cash row does not erase koran history — it only unmatches the line.
  cashAccountId Int?     @unique @map("cash_account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  statement   BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  cashAccount CashAccount?  @relation("LineMatch", fields: [cashAccountId], references: [id], onDelete: SetNull)

  @@index([statementId])
  @@index([date])
  @@index([matched])
  @@map("bank_statement_lines")
}
